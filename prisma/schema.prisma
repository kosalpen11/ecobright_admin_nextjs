generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model User {
  id               String          @id @default(cuid())
  name             String
  email            String          @unique
  passwordHash     String          @map("password_hash")
  role             UserRole        @default(STAFF)
  isActive         Boolean         @default(true) @map("is_active")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  categories       Category[]
  createdProducts  Product[]
  stockMovements   StockMovement[]

  @@map("users")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@index([name])
  @@map("categories")
}

model Product {
  id               String          @id
  title            String
  category         String
  categoryLabel    String          @map("category_label")
  useCase          String?         @map("use_case")
  description      String
  imageUrl         String?         @map("image_url")
  price            Decimal         @db.Decimal(12, 2)
  oldPrice         Decimal?        @map("old_price") @db.Decimal(12, 2)
  badge            String?
  tags             String[]        @default([])
  currency         String          @default("USD")
  inStock          Boolean         @default(true) @map("in_stock")
  sortOrder        Int?            @map("sort_order")
  isActive         Boolean         @default(true) @map("is_active")
  rating           Decimal?        @db.Decimal(5, 2)
  createdOrder     Int?            @map("created_order")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  titleKm          String?         @map("title_km")
  categoryLabelKm  String?         @map("category_label_km")
  useCaseKm        String?         @map("use_case_km")
  descriptionKm    String?         @map("description_km")
  rawCategory      String?         @map("raw_category")
  packQty          Int?            @map("pack_qty")
  holeSize         String?         @map("hole_size")
  sourceSheet      String?         @map("source_sheet")
  sourceBlock      String?         @map("source_block")
  sourceRow        String?         @map("source_row")
  sourceSegment    String?         @map("source_segment")
  needsReview      Boolean         @default(false) @map("needs_review")
  reviewFlags      String[]        @default([]) @map("review_flags")
  migrationBatchId String?         @map("migration_batch_id")
  imageUrls        String[]        @default([]) @map("image_urls")
  stockQty         Int             @default(0) @map("stock_qty")
  createdById      String?         @map("created_by_id")
  createdBy        User?           @relation(fields: [createdById], references: [id])
  stockMovements   StockMovement[]

  @@index([title])
  @@index([category])
  @@map("products")
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String            @map("product_id")
  type        StockMovementType
  quantity    Int
  note        String?
  createdById String            @map("created_by_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  product     Product           @relation(fields: [productId], references: [id])
  createdBy   User              @relation(fields: [createdById], references: [id])

  @@index([productId, createdAt])
  @@map("stock_movements")
}
