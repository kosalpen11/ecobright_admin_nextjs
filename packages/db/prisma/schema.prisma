generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  passwordHash  String          @map("password_hash")
  role          UserRole        @default(STAFF)
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  categories    Category[]
  createdItems  Product[]
  movements     StockMovement[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?   @db.Text
  access_token      String?   @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?   @db.Text
  session_state     String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
  @@index([expires])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@unique([token])
  @@map("verification_tokens")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([name])
  @@index([updatedAt(sort: Desc)])
  @@map("categories")
}

model Product {
  id               String   @id
  title            String
  category         String
  categoryLabel    String   @map("category_label")
  useCase          String?  @map("use_case")
  description      String
  imageUrl         String?  @map("image_url")
  price            Decimal  @db.Decimal(12, 2)
  oldPrice         Decimal? @map("old_price") @db.Decimal(12, 2)
  badge            String?
  tags             String[] @default([])
  currency         String   @default("USD")
  inStock          Boolean  @default(true) @map("in_stock")
  sortOrder        Int?     @map("sort_order")
  isActive         Boolean  @default(true) @map("is_active")
  titleKm          String?  @map("title_km")
  categoryLabelKm  String?  @map("category_label_km")
  useCaseKm        String?  @map("use_case_km")
  descriptionKm    String?  @map("description_km")
  rawCategory      String?  @map("raw_category")
  packQty          Int?     @map("pack_qty")
  holeSize         String?  @map("hole_size")
  needsReview      Boolean  @default(false) @map("needs_review")
  reviewFlags      String[] @default([]) @map("review_flags")
  imageUrls        String[] @default([]) @map("image_urls")
  stockQty         Int      @default(0) @map("stock_qty")
  createdById      String?  @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  createdBy        User?    @relation(fields: [createdById], references: [id])
  stockMovements   StockMovement[]

  @@index([title])
  @@index([category])
  @@index([updatedAt(sort: Desc)])
  @@index([stockQty])
  @@index([needsReview, updatedAt(sort: Desc)])
  @@map("products")
}

model StockMovement {
  id            String            @id @default(cuid())
  productId     String            @map("product_id")
  type          StockMovementType
  quantity      Int
  previousStock Int               @map("previous_stock")
  newStock      Int               @map("new_stock")
  note          String?
  createdById   String            @map("created_by_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy     User              @relation(fields: [createdById], references: [id])

  @@index([productId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([createdById, createdAt(sort: Desc)])
  @@map("stock_movements")
}
